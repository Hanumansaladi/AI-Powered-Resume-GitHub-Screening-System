      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst resumeScore = JSON.parse($('ATS SCORE').item.json.text).ats_score;\nconst githubScore = JSON.parse($('GITHUB SCORE').item.json.text).project_score;\nconst activityScore = $('Active Score').item.json.activity_score;\n\nconst finalScore = (resumeScore * 0.40) + (githubScore * 0.50) + (activityScore * 0.10);\n\nreturn {\n  json: {\n    resume_score: resumeScore,\n    github_score: githubScore,\n    activity_score: activityScore,\n    final_score: Math.round(finalScore)\n  }\n};"
      },
