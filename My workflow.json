    {
      "parameters": {
        "jsCode": "const repos = $('Fetch Repository List').all().map(item => item.json);\n\nconst now = new Date();\nlet activeRepoCount = 0;\nlet mostRecentScore = 0;\n\nfor (const repo of repos) {\n  const lastUpdate = new Date(repo.pushed_at);\n  const monthsAgo = (now - lastUpdate) / (1000 * 60 * 60 * 24 * 30);\n\n  // Count repos active in the last 12 months\n  if (monthsAgo <= 12) {\n    activeRepoCount++;\n  }\n\n  // Track the single most recent update across all repos\n  const recencyScore = monthsAgo <= 3 ? 100 : monthsAgo <= 6 ? 70 : monthsAgo <= 12 ? 40 : 10;\n  if (recencyScore > mostRecentScore) {\n    mostRecentScore = recencyScore;\n  }\n}\n\n// Active repo ratio: how many of their repos are still \"alive\"\nconst totalRepos = repos.length || 1;\nconst activeRatio = Math.min((activeRepoCount / totalRepos) * 100, 100);\n\n// Combine recency (most recent activity) + active ratio (breadth of ongoing activity)\nconst activityScore = Math.round((mostRecentScore * 0.6) + (activeRatio * 0.4));\n\nreturn {\n  json: {\n    activity_score: activityScore,\n    active_repo_count: activeRepoCount,\n    total_repos: totalRepos\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
